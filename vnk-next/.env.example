# ─────────────────────────────────────────────
# VNK-Next environnement
# Copier en .env.local pour le d\u00e9veloppement
# ─────────────────────────────────────────────

# Database (Postgres — m\u00eame base que l'Express actuel pour transition)
DATABASE_URL="postgresql://user:password@localhost:5432/vnk?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/vnk?schema=public"

# NextAuth
AUTH_SECRET="generer-avec-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true

# SSO (optionnel - configurables aussi via section Param\u00e8tres)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Email (SMTP ou SendGrid)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="VNK Automatisation <noreply@vnk.ca>"

# Dropbox Sign (HelloSign)
DROPBOX_SIGN_API_KEY=""

# Upload limits
MAX_UPLOAD_MB="10"
