# ═══════════════════════════════════════════════════════════
# VNK Automatisation — Environnement
# Copier en .env.local pour le développement local
# ═══════════════════════════════════════════════════════════

# ─── Base de données Postgres (Railway) ────────────────────
DATABASE_URL="postgresql://user:password@host:5432/vnk?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/vnk?schema=public"

# ─── NextAuth v5 ───────────────────────────────────────────
# Générer AUTH_SECRET avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ─── SSO (optionnel — configurable aussi via Paramètres) ───
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ─── Email SMTP (gmail ou autre) ───────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="VNK Automatisation <noreply@vnk.ca>"

# ─── Upload ────────────────────────────────────────────────
MAX_UPLOAD_MB="10"

# ─── Note signature électronique ───────────────────────────
# On utilise notre propre canvas de signature (pas Dropbox Sign).
# Le flux : client dessine dans le portail → base64 dans clients_signature_data
# Admin dessine dans /admin/contracts → base64 dans admins_signature_data
# Les deux → contract.status = 'signed' + facture auto générée
